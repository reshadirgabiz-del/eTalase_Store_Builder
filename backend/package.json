{
  "name": "etalase-local-backend",
  "version": "0.1.0",
  "description": "Standalone read-only NestJS backend for local eTalase SDK development",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev:watch": "nodemon",
    "build": "tsc",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.24",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "nodemonConfig": {
    "watch": ["src"],
    "ext": "ts",
    "exec": "ts-node -r tsconfig-paths/register src/main.ts"
  }
}
